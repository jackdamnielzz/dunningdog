# App
NODE_ENV=development
APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_BASE_URL=http://localhost:3000

# Database / Supabase
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dunningdog
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# Google OAuth is configured in Supabase Auth Providers (no extra app env vars required)

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_CONNECT_CLIENT_ID=ca_xxx
STRIPE_CONNECT_CLIENT_SECRET=sk_xxx
STRIPE_PRICE_STARTER_ID=price_xxx
STRIPE_PRICE_PRO_ID=price_xxx
STRIPE_PRICE_GROWTH_ID=price_xxx

# Stripe Billing (separate webhook for subscription events)
STRIPE_BILLING_WEBHOOK_SECRET=whsec_xxx

# Email (SMTP via Namecheap Private Email or any SMTP provider)
SMTP_HOST=mail.privateemail.com
SMTP_PORT=465
SMTP_USER=info@dunningdog.com
SMTP_PASS=your-smtp-password
SMTP_FROM_EMAIL=info@dunningdog.com

# Inngest
INNGEST_EVENT_KEY=inngest-event-key
INNGEST_SIGNING_KEY=inngest-signing-key
CRON_SECRET=change-me-with-long-random-secret

# Monitoring
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
APP_RELEASE=
OBSERVABILITY_TIMEOUT_MS=2000
POSTHOG_KEY=
POSTHOG_HOST=https://eu.i.posthog.com

# Security
ENCRYPTION_KEY=32-bytes-secret-key-change-me

# Admin access (comma-separated email addresses)
ADMIN_EMAILS=your-email@example.com

# Demo mode (optional for local startup without full providers)
DEMO_MODE=true
